# JetBrains IDEs (Rider)
# ===========================
.idea/
*.iml
*.iws
out/

# ===========================
# NuGet Packages
# ===========================
*.nupkg
**/packages/*
!**/packages/build/

# ===========================
# Unity Addressables
# ===========================
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.json*

# ===========================
# Gradle / Android
# ===========================
.gradle/
*.apk
*.aab

# ===========================
# iOS / Xcode
# ===========================
*.xcworkspace
*.xcodeproj

# ===========================
# Shader Variants Cache
# ===========================
*.shadervariants
*.shaderVariants

# ===========================
# Crash Reports & Logs
# ===========================
sysinfo.txt
*.stackdump

# ===========================
# Third Party / Package Manager
# ===========================
/[Pp]ackages/
!/[Pp]ackages/manifest.json
!/[Pp]ackages/packages-lock.json

# ===========================
# Rider / Editor Local Settings
# ===========================
ExportedObj/
.consulo/
*.csproj.user

